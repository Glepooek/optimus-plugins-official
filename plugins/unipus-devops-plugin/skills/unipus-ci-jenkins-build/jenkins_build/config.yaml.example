jenkins:
  url: "http://jenkins.example.com:8080"
  username: "your_username"
  api_token: "your_api_token"   # 优先使用，在 Jenkins → 用户设置 → API Token 中生成
  # password: "your_password"   # 无 api_token 时使用密码

jobs:
  lms-api-test:
    path: "view/mid/job/lms-api-test"
