{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--browser",
        "msedge"
      ]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_TOKEN}"
      }
    },
    "mastergo-magic-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@mastergo/magic-mcp",
        "--token=${MASTERGO_TOKEN}",
        "--url=https://mastergo.com"
      ],
      "env": {}
    },
	"FeishuProjectMcp": {
      "command": "npx",
      "args": [
        "-y",
        "@lark-project/mcp",
        "--domain",
        "https://project.feishu.cn"
      ],
      "env": {
        "MCP_USER_TOKEN": "${FEISHU_PROJECT_TOKEN}"
      }
    }
  }
}